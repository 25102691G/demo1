{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical_case.schema.json",
  "title": "Canonical Clinical Case Schema",
  "type": "object",
  "required": [
    "case_id",
    "raw_input",
    "name",
    "sex",
    "age",
    "population",
    "symptoms"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "default": null
    },
    "raw_input": {
      "type": ["string", "object"],
      "default": null,
      "required": [
        "clinical_presentation",
        "lab_tests",
        "imaging_tests",
        "endoscopy",
        "pathology"
      ],
      "properties": {
        "clinical_presentation": {
          "type": "string",
          "default": ""
        },
        "lab_tests": {
          "type": "string",
          "default": ""
        },
        "imaging_tests": {
          "type": "string",
          "default": ""
        },
        "endoscopy": {
          "type": "string",
          "default": ""
        },
        "pathology": {
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": true
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "sex": {
      "type": "string",
      "enum": ["male", "female", "unknown"],
      "default": "unknown"
    },
    "age": {
      "type": ["number", "null"],
      "default": null
    },
    "population": {
      "type": "string",
      "default": ""
    },
    "symptoms": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "default": ""
          },
          "body_site": {
            "type": ["string", "null"],
            "default": null
          },
          "hpo_code": {
            "type": ["string", "null"],
            "default": null
          },
          "hpo_term": {
            "type": ["string", "null"],
            "default": null
          },
          "matched_body_site": {
            "type": ["string", "null"],
            "default": null
          },
          "similarity_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "default": null
          },
          "status": {
            "type": "string",
            "enum": ["mapped", "unmapped", "unknown"],
            "default": "unknown"
          }
        },
        "additionalProperties": true
      }
    },
    "features": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["name", "similarity_score", "status", "icd10_mapping", "hpo_mapping"],
        "properties": {
          "name": {
            "type": "string",
            "default": ""
          },
          "similarity_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "default": null
          },
          "status": {
            "type": "string",
            "default": "unknown"
          },
          "icd10_mapping": {
            "type": "object",
            "default": {},
            "properties": {
              "chapter": {
                "type": "string",
                "default": ""
              },
              "chapter_code_range": {
                "type": "string",
                "default": ""
              },
              "chapter_name": {
                "type": "string",
                "default": ""
              },
              "section_code_range": {
                "type": "string",
                "default": ""
              },
              "section_name": {
                "type": "string",
                "default": ""
              },
              "category_code": {
                "type": "string",
                "default": ""
              },
              "category_name": {
                "type": "string",
                "default": ""
              },
              "subcategory_code": {
                "type": "string",
                "default": ""
              },
              "subcategory_name": {
                "type": "string",
                "default": ""
              },
              "diagnosis_code": {
                "type": ["string", "null"],
                "default": null
              },
              "diagnosis_name": {
                "type": ["string", "null"],
                "default": null
              }
            },
            "additionalProperties": true
          },
          "hpo_mapping": {
            "type": "object",
            "default": {},
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
