{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical_case.schema.json",
  "title": "Canonical Clinical Case Schema",
  "type": "object",
  "required": [
    "case_id",
    "raw_input",
    "name",
    "sex",
    "age",
    "population",
    "symptoms"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "default": null
    },
    "raw_input": {
      "type": "string",
      "default": null
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "sex": {
      "type": "string",
      "enum": ["male", "female", "unknown"],
      "default": "unknown"
    },
    "age": {
      "type": ["number", "null"],
      "default": null
    },
    "population": {
      "type": "string",
      "default": ""
    },
    "symptoms": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "default": ""
          },
          "body_site": {
            "type": ["string", "null"],
            "default": null
          },
          "hpo_code": {
            "type": ["string", "null"],
            "default": null
          },
          "hpo_term": {
            "type": ["string", "null"],
            "default": null
          },
          "matched_body_site": {
            "type": ["string", "null"],
            "default": null
          },
          "similarity_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "default": null
          },
          "status": {
            "type": "string",
            "enum": ["mapped", "unmapped", "unknown"],
            "default": "unknown"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
