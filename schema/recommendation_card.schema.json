{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recommendation_card.schema.json",
  "title": "Recommendation Card Schema",
  "type": "object",
  "required": [
    "record_type",
    "card_id",
    "source_statement_id",
    "disease",
    "guideline",
    "clinical_stage",
    "raw_chunk_text",
    "action",
    "evidence",
    "source_location"
  ],
  "properties": {
    "record_type": {
      "type": "string",
      "const": "recommendation_card"
    },
    "card_id": {
      "type": "string"
    },
    "source_statement_id": {
      "type": ["string", "null"]
    },
    "disease": {
      "type": "string"
    },
    "guideline": {
      "type": "object",
      "required": ["title", "source_file", "doc_type"],
      "properties": {
        "title": {
          "type": "string"
        },
        "source_file": {
          "type": ["string", "null"]
        },
        "doc_type": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "clinical_stage": {
      "type": "string",
      "$comment": "TODO: 后续需优化为enum类"
    },
    "clinical_task": {
      "type": ["string", "null"]
    },
    "population": {
      "type": ["string", "null"]
    },
    "condition": {
      "type": ["string", "null"]
    },
    "raw_chunk_text": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safety_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_quality_normalized",
        "evidence_quality_normalized_info"
      ],
      "properties": {
        "evidence_quality_raw": {
          "type": ["string", "null"]
        },
        "evidence_quality_normalized": {
          "type": "number",
          "minimum": 0.6,
          "maximum": 1
        },
        "evidence_quality_normalized_info": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source_location": {
      "type": "object",
      "required": ["page_start", "page_end"],
      "properties": {
        "pdf": {
          "type": "string"
        },
        "page_start": {
          "type": "integer",
          "minimum": 1
        },
        "page_end": {
          "type": "integer",
          "minimum": 1
        },
        "quote": {
          "type": "string"
        },
        "source_span": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
